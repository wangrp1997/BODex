      <state_interface data_type="double" name="fx"/>
      <state_interface data_type="double" name="fy"/>
      <state_interface data_type="double" name="fz"/>
    </gpio>
    <gpio name="RFT0">
      <command_interface data_type="double" name="fz"/>
      <!-- 暂时只支持控制指尖的法向力 -->
      <state_interface data_type="double" name="fx"/>
      <state_interface data_type="double" name="fy"/>
      <state_interface data_type="double" name="fz"/>
    </gpio>
    <gpio name="LFT0">
      <command_interface data_type="double" name="fz"/>
      <!-- 暂时只支持控制指尖的法向力 -->
      <state_interface data_type="double" name="fx"/>
      <state_interface data_type="double" name="fy"/>
      <state_interface data_type="double" name="fz"/>
    </gpio>
  </ros2_control>
  <!-- construct pure URDF end -->
</robot>
